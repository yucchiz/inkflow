{
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run format:*)",
      "Bash(npm run test:*)",
      "Bash(npm run preview:*)",
      "Bash(npx:*)",
      "Bash(git diff:*)",
      "Bash(git diff --staged:*)",
      "Bash(git diff --cached:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git stash:*)",
      "Bash(git checkout -- src/:*)",
      "Read(*)",
      "Write(src/**)",
      "Edit(src/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint && npm run format:check && npm run test -- --run"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write(src/**/*.ts*)|Edit(src/**/*.ts*)",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | tail -20 || true"
          }
        ]
      }
    ]
  }
}
