{
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx vite:*)",
      "Bash(git diff:*)",
      "Bash(git diff --staged:*)",
      "Bash(git diff --cached:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git stash:*)",
      "Read(*)",
      "Write(src/**)",
      "Write(public/**)",
      "Edit(src/**)",
      "Edit(public/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "npm run build 2>&1 | tail -20 && npm test 2>&1 | tail -30"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write(src/**/*.tsx)|Edit(src/**/*.tsx)|Write(src/**/*.ts)|Edit(src/**/*.ts)",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | tail -20 || true"
          }
        ]
      }
    ]
  }
}
