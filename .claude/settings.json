{
  "permissions": {
    "allow": [
      "Bash(swift build:*)",
      "Bash(swift test:*)",
      "Bash(swift package:*)",
      "Bash(xcodebuild:*)",
      "Bash(git diff:*)",
      "Bash(git diff --staged:*)",
      "Bash(git diff --cached:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git stash:*)",
      "Read(*)",
      "Write(Sources/**)",
      "Write(Tests/**)",
      "Write(App/**)",
      "Edit(Sources/**)",
      "Edit(Tests/**)",
      "Edit(App/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "swift build 2>&1 | tail -20 && swift test 2>&1 | tail -30"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write(Sources/**/*.swift)|Edit(Sources/**/*.swift)|Write(App/**/*.swift)|Edit(App/**/*.swift)",
        "hooks": [
          {
            "type": "command",
            "command": "swift build 2>&1 | tail -20 || true"
          }
        ]
      }
    ]
  }
}
